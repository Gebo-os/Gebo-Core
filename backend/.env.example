# Default local model (use gebo-custom after running scripts/create-gebo-model.ps1)
OLLAMA_MODEL=llama3.2:3b
# OLLAMA_MODEL=gebo-custom
OLLAMA_BASE_URL=http://localhost:11434

# Codex integration (local CLI). CODEX_WORKDIR defaults to the project root.
CODEX_ENABLED=true
# CODEX_WORKDIR=C:\path\to\gebo-core-private
CODEX_TIMEOUT=900

# Frontend origins allowed by backend CORS (use * for full internet access)
CORS_ORIGINS=*

# Bind host — 0.0.0.0 allows LAN/remote clients
GEBO_BIND_HOST=0.0.0.0
GEBO_BACKEND_PORT=8000
GEBO_FRONTEND_PORT=3000
GEBO_BACKEND_URL=http://127.0.0.1:8000
GEBO_FRONTEND_URL=http://localhost:3000

# Offline knowledge wiki (free, local ZIM file via libzim).
# Download a ZIM from https://download.kiwix.org/zim/ and place it in
# backend/data/wiki/ (Gebo auto-detects the first *.zim there), or set the path.
WIKI_ENABLED=true
# WIKI_ZIM_PATH=C:\path\to\wikipedia.zim
# Auto-consult mode: nocontext (only when no memory match) | always | off
WIKI_AUTO=nocontext
WIKI_RESULTS=3

# Release mode: owner (local private) | production (Supabase + Vercel public deploy)
GEBO_RELEASE_MODE=owner

# Production release (leave unset for Owner Node)
# --- Official V1: Supabase + Vercel (see docs/official/09-official-v1-release.md) ---
# 10 required controls — configure all for 10/10 production readiness
#
# 1. Supabase Postgres — https://supabase.com/dashboard
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# DATABASE_URL=postgresql://postgres:...@db.xxx.supabase.co:5432/postgres
#
# 2. pgvector — enable in Supabase SQL: CREATE EXTENSION vector;
# (uses DATABASE_URL above)
#
# 3. Supabase Auth — https://supabase.com/docs/guides/auth
# SUPABASE_ANON_KEY=
# SUPABASE_JWT_SECRET=
#
# 4. Supabase Storage — https://supabase.com/docs/guides/storage
# (uses SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY; bucket: gebo-documents)
#
# 5. Vercel frontend — https://vercel.com/signup
# VERCEL_URL=your-app.vercel.app
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
#
# 6. Cloudflare Turnstile — https://dash.cloudflare.com/?to=/:account/turnstile
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
#
# 7. Upstash Redis — https://console.upstash.com/
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
#
# 8. Stripe — https://dashboard.stripe.com/register
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
#
# 9. OpenAI (Vercel AI Gateway / Gebo AI Gateway) — https://platform.openai.com/api-keys
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
#
# 10. Supabase RLS — https://supabase.com/docs/guides/auth/row-level-security
# (apply backend/data/schema/official-v1.sql + RLS policies)
#
# Optional: route /chat through ai_gateway module
# GEBO_USE_AI_GATEWAY=false
#
# Recommended (not required for 10/10 score):
# RESEND_API_KEY=          # https://resend.com/signup
# SENTRY_DSN=              # https://sentry.io/signup/
# LANGFUSE_PUBLIC_KEY=     # https://cloud.langfuse.com
# LANGFUSE_SECRET_KEY=
# NEXT_PUBLIC_POSTHOG_KEY= # https://posthog.com/signup
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# XAI_API_KEY=

# --- Optional GCP / Firebase enterprise path (see docs/official/08-production-release.md) ---
# FIREBASE_PROJECT_ID=
# FIREBASE_API_KEY=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLOUD_PROJECT=
# RECAPTCHA_SITE_KEY=
# RECAPTCHA_PROJECT_ID=
# DATABASE_URL=postgresql://...
# GCS_BUCKET=
# GEBO_AUTH_ENABLED=false
# GEBO_MODEL_ARMOR_ENABLED=false
# GEBO_SECRET_MANAGER_ENABLED=true
# GEBO_SECRET_NAMES=firebase-api-key,database-url
# RECAPTCHA_API_KEY=
