# Default local model (use gebo-custom after running scripts/create-gebo-model.ps1)
OLLAMA_MODEL=llama3.2:3b
# OLLAMA_MODEL=gebo-custom
OLLAMA_BASE_URL=http://localhost:11434

# Codex integration (local CLI). CODEX_WORKDIR defaults to the project root.
CODEX_ENABLED=true
# CODEX_WORKDIR=C:\path\to\gebo-core-private
CODEX_TIMEOUT=900

# Frontend origins allowed by backend CORS (use * for full internet access)
CORS_ORIGINS=*

# Bind host — 0.0.0.0 allows LAN/remote clients
GEBO_BIND_HOST=0.0.0.0
GEBO_BACKEND_PORT=8000
GEBO_FRONTEND_PORT=3000
GEBO_BACKEND_URL=http://127.0.0.1:8000
GEBO_FRONTEND_URL=http://localhost:3000

# Offline knowledge wiki (free, local ZIM file via libzim).
# Download a ZIM from https://download.kiwix.org/zim/ and place it in
# backend/data/wiki/ (Gebo auto-detects the first *.zim there), or set the path.
WIKI_ENABLED=true
# WIKI_ZIM_PATH=C:\path\to\wikipedia.zim
# Auto-consult mode: nocontext (only when no memory match) | always | off
WIKI_AUTO=nocontext
WIKI_RESULTS=3
